{
  "name": "trade-imports-schemas",
  "version": "1.0.0",
  "description": "Defra JSON Schema definitions for CDP trade import journeys, aligned to UN/CEFACT Buy-Ship-Pay (BSP) D23B",
  "type": "module",
  "scripts": {
    "validate-schemas": "node scripts/validate-schemas.js",
    "validate-samples": "node scripts/validate-samples.js",
    "convert:traces": "node scripts/traces-to-unvtd.js",
    "build-dictionary:gbn-ag": "node scripts/build-data-dictionary.js gbn-ag",
    "build-pims-mapping:gbn-ag": "node scripts/gbn-ag-data-import/build-pims-data-mapping.js",
    "test": "node --test scripts/traces-to-unvtd.test.js scripts/build-data-dictionary.test.js"
  },
  "keywords": [
    "json-schema",
    "defra",
    "cdp",
    "imports",
    "uncefact",
    "buy-ship-pay",
    "gbn-ag"
  ],
  "author": "DEFRA",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^3.0.1",
    "fast-xml-parser": "^5.0.9"
  }
}