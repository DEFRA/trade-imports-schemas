{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gbn-ag-event-notification-submission-withdrawn-v1.schema.json",
  "title": "GBN-AG NotificationSubmissionWithdrawn event (v1)",
  "description": "Event emitted when a submitted GBN-AG notification is withdrawn (SUBMITTED -> WITHDRAWN, or AMEND -> WITHDRAWN). The data payload is the full notification snapshot at the point of withdrawal, with `notificationStatusCode = WITHDRAWN` and `functionCode = 1` (Cancellation). `versionId` carries forward from the prior state.",

  "allOf": [
    { "$ref": "profiles/imports/messaging/event-envelope-v1.schema.json" },
    {
      "type": "object",
      "properties": {
        "aggregateType": { "const": "Notification" },
        "subType":       { "const": "GBN-AG" },
        "eventType":     { "const": "uk.gov.defra.trade.imports.animals.NotificationSubmissionWithdrawn" },
        "data": {
          "allOf": [
            { "$ref": "gbn-ag-v1.schema.json" },
            {
              "type": "object",
              "required": ["exchangedDocument"],
              "properties": {
                "exchangedDocument": {
                  "type": "object",
                  "required": ["notificationStatusCode", "versionId", "functionCode"],
                  "properties": {
                    "notificationStatusCode": { "const": "WITHDRAWN" },
                    "versionId":              { "type": "integer", "minimum": 1 },
                    "functionCode":           { "const": "1" }
                  }
                }
              }
            }
          ]
        }
      }
    }
  ]
}
