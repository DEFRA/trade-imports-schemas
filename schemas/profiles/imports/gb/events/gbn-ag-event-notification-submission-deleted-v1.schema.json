{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gbn-ag-event-notification-submission-deleted-v1.schema.json",
  "title": "GBN-AG NotificationSubmissionDeleted event (v1)",
  "description": "Event emitted when a submitted GBN-AG notification is deleted (SUBMITTED -> DELETED, or AMEND -> DELETED). The data payload is the full notification snapshot at the point of deletion, with `notificationStatusCode = DELETED`. `versionId` carries forward from the prior state.",

  "allOf": [
    { "$ref": "profiles/imports/messaging/event-envelope-v1.schema.json" },
    {
      "type": "object",
      "properties": {
        "aggregateType": { "const": "Notification" },
        "subType":       { "const": "GBN-AG" },
        "eventType":     { "const": "uk.gov.defra.trade.imports.animals.NotificationSubmissionDeleted" },
        "data": {
          "allOf": [
            { "$ref": "gbn-ag-v1.schema.json" },
            {
              "type": "object",
              "required": ["exchangedDocument"],
              "properties": {
                "exchangedDocument": {
                  "type": "object",
                  "required": ["notificationStatusCode", "versionId"],
                  "properties": {
                    "notificationStatusCode": { "const": "DELETED" },
                    "versionId":              { "type": "integer", "minimum": 1 }
                  }
                }
              }
            }
          ]
        }
      }
    }
  ]
}
