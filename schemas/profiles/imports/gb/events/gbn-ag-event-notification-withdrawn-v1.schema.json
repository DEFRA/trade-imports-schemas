{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gbn-ag-event-notification-withdrawn-v1.schema.json",
  "title": "GBN-AG NotificationWithdrawn event (v1)",
  "description": "Event emitted when a draft GBN-AG notification is withdrawn before submission (DRAFT -> WITHDRAWN). The data payload carries only what is needed to identify the notification and signal the withdrawal: the notification `identifier`, `notificationStatusCode = WITHDRAWN`, and `functionCode = 1` (Cancellation). A draft has no submitted snapshot to carry forward.",

  "allOf": [
    { "$ref": "profiles/imports/messaging/event-envelope-v1.schema.json" },
    {
      "type": "object",
      "properties": {
        "aggregateType": { "const": "Notification" },
        "subType":       { "const": "GBN-AG" },
        "eventType":     { "const": "uk.gov.defra.trade.imports.animals.NotificationWithdrawn" },
        "data": {
          "type": "object",
          "required": ["$model", "$type", "exchangedDocument"],
          "properties": {
            "$model": { "const": "defra/certificate-internal/1" },
            "$type":  { "const": "gbn-ag" },
            "exchangedDocument": {
              "type": "object",
              "required": ["identifier", "notificationStatusCode", "functionCode"],
              "properties": {
                "identifier":             { "type": "string" },
                "notificationStatusCode": { "const": "WITHDRAWN" },
                "functionCode":           { "const": "1" }
              }
            }
          }
        }
      }
    }
  ]
}
