{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gbn-ag-event-notification-created-v1.schema.json",
  "title": "GBN-AG NotificationCreated event (v1)",
  "description": "Event emitted when a new GBN-AG notification is created (entry -> DRAFT). The data payload carries the minimum to identify the notification and pin the goods: the notification `identifier`, the workflow status (`notificationStatusCode = DRAFT`), the consignment-level `originCountry`, and at least one trade line with an `applicableClassification`. Sub-shapes reference `gbn-ag-v1.schema.json`'s `$def`s (and the core `TradeCountry`) so any change to the canonical types flows through. The full SUBMITTED-grade contract lives on the NotificationSubmitted event.",

  "allOf": [
    { "$ref": "profiles/imports/messaging/event-envelope-v1.schema.json" },
    {
      "type": "object",
      "properties": {
        "aggregateType": { "const": "Notification" },
        "subType":       { "const": "GBN-AG" },
        "eventType":     { "const": "uk.gov.defra.trade.imports.animals.NotificationCreated" },
        "data": {
          "type": "object",
          "required": ["$model", "$type", "exchangedDocument", "specifiedConsignment"],
          "properties": {
            "$model": { "const": "defra/certificate-internal/1" },
            "$type":  { "const": "gbn-ag" },
            "exchangedDocument": {
              "type": "object",
              "required": ["identifier", "notificationStatusCode"],
              "properties": {
                "identifier":             { "type": "string" },
                "notificationStatusCode": { "const": "DRAFT" }
              }
            },
            "specifiedConsignment": {
              "type": "object",
              "required": ["originCountry", "includedConsignmentItem"],
              "properties": {
                "originCountry": {
                  "$ref": "../../../core/defra-unvtd-canonical-core-v1.schema.json#/$defs/TradeCountry"
                },
                "includedConsignmentItem": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "required": ["includedTradeLineItem"],
                    "properties": {
                      "includedTradeLineItem": {
                        "type": "array",
                        "minItems": 1,
                        "items": {
                          "type": "object",
                          "required": ["applicableClassification"],
                          "properties": {
                            "applicableClassification": {
                              "type": "array",
                              "minItems": 1,
                              "items": { "$ref": "gbn-ag-v1.schema.json#/$defs/gbnAgApplicableClassification" }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}
