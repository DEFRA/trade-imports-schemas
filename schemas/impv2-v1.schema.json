{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/DEFRA/trade-imports-schemas/blob/main/schemas/impv2-v1.schema.json",
  "title": "IMPv2 Domain Model v1",
  "description": "Domain definitions for IMPv2 (live animals) import notifications. Extends imports-common-v1 with animal-specific types. Structurally compatible with DEFRA/ipaffs-imports-notification-schema, curated for the published event contract.",

  "$defs": {
    "Purpose": {
      "type": "object",
      "description": "Purpose of consignment details for live animals journey.",
      "additionalProperties": false,
      "properties": {
        "purposeGroup": {
          "type": "string",
          "description": "Purpose group of consignment (general purpose)",
          "enum": [
            "For Import",
            "For NON-Conforming Consignments",
            "For Transhipment to",
            "For Transit to 3rd Country",
            "For Re-Import",
            "For Private Import",
            "For Transfer To",
            "For Import Re-Conformity Check",
            "For Import Non-Internal Market"
          ]
        },
        "internalMarketPurpose": {
          "type": "string",
          "description": "Detailed purpose of internal market purpose group",
          "enum": [
            "Animal Feeding Stuff",
            "Human Consumption",
            "Pharmaceutical Use",
            "Technical Use",
            "Other",
            "Commercial Sale",
            "Commercial sale or change of ownership",
            "Rescue",
            "Breeding",
            "Research",
            "Racing or Competition",
            "Approved Premises or Body",
            "Companion Animal not for Resale or Rehoming",
            "Production",
            "Slaughter",
            "Fattening",
            "Game Restocking",
            "Registered Horses"
          ]
        },
        "exitBIP": {
          "type": "string",
          "minLength": 1,
          "maxLength": 15,
          "description": "Exit Border Inspection Post"
        }
      }
    },

    "AnimalCertification": {
      "type": "string",
      "description": "Certification for animal. Compatible with ipaffs-imports-notification-schema AnimalCertification.",
      "enum": [
        "Animal feeding stuff",
        "Approved",
        "Artificial reproduction",
        "Breeding",
        "Circus",
        "Commercial sale",
        "Commercial sale or change of ownership",
        "Fattening",
        "Game restocking",
        "Human consumption",
        "Internal market",
        "Other",
        "Personally owned pets not for rehoming",
        "Pets",
        "Production",
        "Quarantine",
        "Racing/Competition",
        "Registered equidae",
        "Registered",
        "Rejected or Returned consignment",
        "Relaying",
        "Rescue/Rehoming",
        "Research",
        "Slaughter",
        "Technical/Pharmaceutical use",
        "Transit",
        "Zoo/Collection"
      ]
    },

    "VeterinaryInformation": {
      "type": "object",
      "description": "Veterinary checks and document details for live animal imports",
      "additionalProperties": false,
      "properties": {
        "establishmentsOfOrigin": {
          "type": "array",
          "description": "List of approved establishments which issued veterinary documents",
          "items": { "$ref": "common-v1.schema.json#/$defs/ApprovedEstablishment" }
        },
        "veterinaryDocument": {
          "type": "string",
          "description": "Veterinary document identification"
        },
        "veterinaryDocumentIssueDate": {
          "type": "string",
          "description": "Veterinary document issue date"
        },
        "accompanyingDocuments": {
          "type": "array",
          "description": "Accompanying documents valid for live animal imports. Uses allOf to inherit common AccompanyingDocument structure while restricting documentType enum to only animal-relevant types (veterinary certificates, transport documents, etc). This provides schema-level type safety without requiring the common layer to pre-categorize document types by journey.",
          "items": {
            "allOf": [
              { "$ref": "common-v1.schema.json#/$defs/AccompanyingDocument" },
              {
                "properties": {
                  "documentType": {
                    "description": "Document types valid for live animal imports (IMPv2, CVEDA). Subset of common DocumentType enum.",
                    "enum": [
                      "airWaybill",
                      "billOfLading",
                      "cargoManifest",
                      "catchCertificate",
                      "commercialDocument",
                      "commercialInvoice",
                      "containerManifest",
                      "customsDeclaration",
                      "docom",
                      "healthCertificate",
                      "inspectionCertificate",
                      "itahc",
                      "journeyLog",
                      "latestVeterinaryHealthCertificate",
                      "letterOfAuthority",
                      "licenseOrAuthorisation",
                      "originCertificate",
                      "other",
                      "packingList",
                      "railwayBill",
                      "roadConsignmentNote",
                      "seaWaybill",
                      "veterinaryHealthCertificate"
                    ]
                  }
                }
              }
            ]
          }
        }
      }
    },

    "Commodities": {
      "description": "Commodities for live animal imports. Extends common Commodities with animal-specific certification.",
      "allOf": [
        { "$ref": "common-v1.schema.json#/$defs/Commodities"},
        {
          "properties": {
            "includeNonAblactedAnimals": {
              "type": "boolean",
              "description": "Does consignment contain non-ablacted (unweaned) animals"
            },
            "animalsCertifiedAs": {
              "$ref": "#/$defs/AnimalCertification"
            }
          }
        }
      ]
    }
  }
}
