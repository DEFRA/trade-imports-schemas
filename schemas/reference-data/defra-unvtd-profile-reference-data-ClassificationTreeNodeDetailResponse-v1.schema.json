{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "defra-unvtd-profile-reference-data-ClassificationTreeNodeDetailResponse.schema.json",
  "title": "Defra UNVTD profile — ClassificationTreeNodeDetailResponse",
  "allOf": [
    {
      "$ref": "defra-unvtd-profile-reference-data-core-v1.schema.json"
    },
    {
      "type": "object",
      "required": [
        "source",
        "treeId",
        "nodePath",
        "node"
      ],
      "properties": {
        "source": {
          "$ref": "defra-unvtd-profile-reference-data-core.schema.json#/$defs/ReferenceDataSource"
        },
        "treeId": {
          "$ref": "defra-unvtd-profile-reference-data-core.schema.json#/$defs/ClassificationTreeId"
        },
        "nodePath": {
          "type": "string"
        },
        "node": {
          "type": "object",
          "required": [
            "cnCode",
            "selectable"
          ],
          "properties": {
            "cnCode": {
              "$ref": "defra-unvtd-profile-reference-data-core.schema.json#/$defs/CnCodeQualified"
            },
            "selectable": {
              "type": "boolean"
            },
            "nodeType": {
              "type": "string"
            }
          }
        },
        "attributes": {
          "type": "array",
          "items": {
            "$ref": "defra-unvtd-profile-reference-data-core.schema.json#/$defs/NodeAttribute"
          }
        },
        "classificationSections": {
          "type": "array",
          "items": {
            "$ref": "defra-unvtd-profile-reference-data-core.schema.json#/$defs/ClassificationSection"
          }
        },
        "taxons": {
          "type": "array",
          "items": {
            "$ref": "defra-unvtd-profile-reference-data-core.schema.json#/$defs/Taxon"
          }
        },
        "resolvedProductClassification": {
          "type": "object",
          "properties": {
            "systemId": {
              "type": "string"
            },
            "classCode": {
              "type": "string"
            },
            "className": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "retrievedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  ]
}