{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "defra-unvtd-profile-reference-data-ClassificationTreeNodeDetailResponse.schema.json",
  "title": "Defra UNVTD profile — ClassificationTreeNodeDetailResponse",
  "allOf": [
    {
      "$ref": "defra-unvtd-profile-reference-data-core-v1.schema.json"
    },
    {
      "type": "object",
      "required": [
        "source",
        "treeId",
        "nodePath",
        "node",
        "nodeId"
      ],
      "properties": {
        "source": {
          "$ref": "defra-unvtd-profile-reference-data-core-v1.schema.json#/$defs/ReferenceDataSource"
        },
        "treeId": {
          "$ref": "defra-unvtd-profile-reference-data-core-v1.schema.json#/$defs/ClassificationTreeId"
        },
        "nodePath": {
          "type": "string"
        },
        "nodeId": {
          "type": "string"
        },
        "node": {
          "type": "object",
          "required": [
            "selectable"
          ],
          "properties": {
            "cnCode": {
              "$ref": "defra-unvtd-profile-reference-data-core-v1.schema.json#/$defs/CnCodeQualified"
            },
            "certificateModel": {
              "$ref": "defra-unvtd-profile-reference-data-core-v1.schema.json#/$defs/CertificateModelReference",
              "description": "Certificate model if applicable (for example lower-level ITACHS certificate models)."
            },
            "selectable": {
              "type": "boolean"
            },
            "nodeType": {
              "type": "string"
            },
            "label": {
              "type": "string"
            }
          }
        },
        "attributes": {
          "type": "array",
          "items": {
            "$ref": "defra-unvtd-profile-reference-data-core-v1.schema.json#/$defs/NodeAttribute"
          }
        },
        "documentTypes": {
          "type": "array",
          "items": {
            "$ref": "defra-unvtd-profile-reference-data-core-v1.schema.json#/$defs/DocumentNodeAttribute"
          }
        },
        "classificationSectionGroups": {
          "type": "array",
          "items": {
            "$ref": "defra-unvtd-profile-reference-data-core-v1.schema.json#/$defs/ClassificationSectionGroup"
          }
        },
        "legislationAttributes": {
          "type": "array",
          "items": {
            "$ref": "defra-unvtd-profile-reference-data-core-v1.schema.json#/$defs/LegislationAttribute"
          }
        },
        "taxons": {
          "type": "array",
          "items": {
            "$ref": "defra-unvtd-profile-reference-data-core-v1.schema.json#/$defs/Taxon"
          }
        },
        "invasiveTaxons": {
          "type": "array",
          "items": {
            "$ref": "defra-unvtd-profile-reference-data-core-v1.schema.json#/$defs/Taxon"
          }
        },
        "retrievedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  ]
}