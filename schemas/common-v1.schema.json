{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/DEFRA/trade-imports-schemas/blob/main/schemas/common-v1.schema.json",
  "title": "Trade Imports Common Domain Model",
  "description": "Shared domain definitions for all import notification journeys (IMPv2, CVEDA, CVEDP, etc.). W",

  "$defs": {
    "ReferenceNumber": {
      "type": "string",
      "description": "Notification reference number"
    },

    "NotificationType": {
      "type": "string",
      "enum": [
        "IMPv2",
        "CVEDA",
        "CVEDP",
        "CVEDPP",
        "CVEDD"
      ],
      "description": "Certificate type discriminator"
    },

    "NotificationStatus": {
      "type": "string",
      "enum": ["DRAFT", "AMENDED", "SUBMITTED", "CANCELLED", "REJECTED"],
      "description": "Lifecycle status of the notification"
    },

    "EconomicOperator": {
      "type": "object",
      "description": "An organisation as part of the DEFRA system. Compatible with ipaffs-imports-notification-schema EconomicOperator.",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "The unique identifier of this organisation"
        },
        "type": {
          "type": "string",
          "description": "Type of organisation",
          "enum": [
            "consignee",
            "destination",
            "exporter",
            "importer",
            "charity",
            "commercial transporter",
            "commercial transporter - user added",
            "private transporter",
            "temporary address",
            "premises of origin",
            "organisation branch address",
            "packer",
            "pod"
          ]
        },
        "status": {
          "type": "string",
          "description": "Status of organisation",
          "enum": [
            "approved",
            "nonapproved",
            "suspended"
          ]
        },
        "companyName": {
          "type": "string",
          "minLength": 0,
          "maxLength": 255,
          "description": "Name of organisation"
        },
        "individualName": {
          "type": "string",
          "minLength": 0,
          "maxLength": 255,
          "description": "Individual name"
        },
        "address": { "$ref": "#/$defs/EconomicOperatorAddress" },
        "approvalNumber": {
          "type": "string",
          "minLength": 0,
          "maxLength": 100,
          "description": "Approval Number which identifies an Economic Operator unambiguously per type per country"
        },
        "otherIdentifier": {
          "type": "string",
          "minLength": 0,
          "maxLength": 100,
          "description": "Optional Business General Number (Aggregation Code)"
        },
        "tracesId": {
          "type": "integer",
          "description": "Traces Id of the economic operator generated by IPAFFS"
        }
      }
    },

    "EconomicOperatorAddress": {
      "type": "object",
      "description": "Address of economic operator",
      "additionalProperties": false,
      "properties": {
        "addressLine1": {
          "type": "string",
          "minLength": 0,
          "maxLength": 255,
          "description": "1st line of address"
        },
        "addressLine2": {
          "type": "string",
          "minLength": 0,
          "maxLength": 255,
          "description": "2nd line of address"
        },
        "addressLine3": {
          "type": "string",
          "minLength": 0,
          "maxLength": 255,
          "description": "3rd line of address"
        },
        "city": {
          "type": "string",
          "minLength": 0,
          "maxLength": 58,
          "description": "City"
        },
        "postalZipCode": {
          "type": "string",
          "minLength": 0,
          "maxLength": 32,
          "description": "Post / zip code"
        },
        "countryISOCode": {
          "type": "string",
          "pattern": "^([A-Z]{2}||[A-Z]{2}-[A-Z]{2,3})$",
          "description": "Country 2-digit ISO code"
        },
        "email": {
          "type": "string",
          "maxLength": 255,
          "description": "Email address"
        },
        "ukTelephone": {
          "type": "string",
          "minLength": 9,
          "maxLength": 11,
          "description": "UK phone number"
        },
        "telephone": {
          "type": "string",
          "minLength": 1,
          "maxLength": 30,
          "description": "Telephone number"
        },
        "internationalTelephone": {
          "type": "object",
          "additionalProperties": false,
          "description": "International phone number",
          "properties": {
            "countryCode": {
              "type": "string",
              "minLength": 1,
              "maxLength": 3,
              "description": "Country code of phone number"
            },
            "subscriberNumber": {
              "type": "string",
              "minLength": 1,
              "maxLength": 12,
              "description": "Phone number"
            }
          },
          "required": [
            "countryCode",
            "subscriberNumber"
          ]
        }
      }
    },

    "Country": {
      "type": "string",
      "minLength": 2,
      "maxLength": 6,
      "pattern": "^([A-Z]{2}||[A-Z]{2}-[A-Z]{2,3})$",
      "description": "ISO code of country"
    },

    "CommodityComplement": {
      "type": "object",
      "description": "Commodity complement identifying what is being imported. Compatible with ipaffs-imports-notification-schema commodityComplement items.",
      "additionalProperties": false,
      "properties": {
        "uniqueComplementID": {
          "type": "string",
          "minLength": 0,
          "maxLength": 36,
          "description": "Stable UUID for this commodity line (from upstream schema)"
        },
        "commodityID": {
          "type": "string",
          "minLength": 1,
          "maxLength": 20,
          "description": "The unique commodity ID (HS code)"
        },
        "commodityDescription": {
          "type": "string",
          "description": "Free text commodity description"
        },
        "complementID": {
          "type": "integer",
          "minimum": 0,
          "description": "Identifier of complement. Also used to link to complementParameterSet"
        },
        "complementName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255,
          "description": "Represents the lowest granularity name for the commodity selected"
        },
        "speciesName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "Species name"
        },
        "speciesNomination": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "Species nomination"
        },
        "speciesTypeName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255,
          "description": "Species type name"
        },
        "speciesType": {
          "type": "string",
          "minLength": 1,
          "maxLength": 15,
          "description": "Species type identifier of commodity"
        },
        "speciesClassName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80,
          "description": "Species class name of commodity (from upstream schema)"
        },
        "speciesClass": {
          "type": "string",
          "minLength": 1,
          "maxLength": 15,
          "description": "Species class identifier of commodity"
        },
        "speciesFamilyName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80,
          "description": "Species family name of commodity"
        },
        "speciesFamily": {
          "type": "string",
          "minLength": 1,
          "maxLength": 15,
          "description": "Species family identifier of commodity (from upstream schema)"
        },
        "speciesCommonName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255,
          "description": "Species common name (from upstream schema)"
        },
        "speciesID": {
          "type": "string",
          "description": "Species identifier"
        },
        "isCdsMatched": {
          "type": "boolean",
          "description": "Whether commodity was matched via CDS (from upstream schema)"
        }
      }
    },

    "ComplementParameterSet": {
      "type": "object",
      "description": "Additional data for a commodityComplement containing quantity and identifier data. Compatible with ipaffs-imports-notification-schema complementParameterSet items.",
      "additionalProperties": false,
      "properties": {
        "uniqueComplementID": {
          "type": "string",
          "minLength": 0,
          "maxLength": 36,
          "description": "Links back to the CommodityComplement (from upstream schema)"
        },
        "complementID": {
          "type": "integer",
          "minimum": 0,
          "description": "Links back to the CommodityComplement"
        },
        "speciesID": {
          "type": "string"
        },
        "keyDataPair": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "key": {
                "type": "string",
                "minLength": 1,
                "maxLength": 255
              },
              "data": {
                "type": "string",
                "minLength": 1,
                "maxLength": 255
              }
            }
          }
        },
        "identifiers": {
          "type": "array",
          "description": "Data used to identify the complements inside an IMP consignment",
          "items": { "$ref": "#/$defs/Identifier" }
        }
      }
    },

    "Identifier": {
      "type": "object",
      "description": "Individual animal or commodity identifier within a consignment.",
      "additionalProperties": false,
      "properties": {
        "speciesNumber": {
          "type": "integer",
          "minimum": 0,
          "description": "Number used to identify which item the identifiers are related to"
        },
        "data": {
          "type": "object",
          "description": "List of identifiers and their keys (e.g. passport, microchip, earTag)",
          "additionalProperties": { "type": "string" }
        },
        "isPlaceOfDestinationThePermanentAddress": {
          "type": "boolean",
          "description": "Is the place of destination the permanent address?"
        },
        "permanentAddress": {
          "$ref": "#/$defs/EconomicOperator",
          "description": "Permanent address of the species"
        }
      }
    },

    "Purpose": {
      "type": "object",
      "description": "Purpose of consignment including purpose group and internal market purpose. Journey-specific schemas may restrict valid enum values.",
      "additionalProperties": false,
      "properties": {
        "purposeGroup": {
          "type": "string",
          "description": "Purpose group of consignment (general purpose)",
          "enum": [
            "For Import",
            "For NON-Conforming Consignments",
            "For Transhipment to",
            "For Transit to 3rd Country",
            "For Re-Import",
            "For Private Import",
            "For Transfer To",
            "For Import Re-Conformity Check",
            "For Import Non-Internal Market"
          ]
        },
        "internalMarketPurpose": {
          "type": "string",
          "description": "Detailed purpose of internal market purpose group",
          "enum": [
            "Animal Feeding Stuff",
            "Human Consumption",
            "Pharmaceutical Use",
            "Technical Use",
            "Other",
            "Commercial Sale",
            "Commercial sale or change of ownership",
            "Rescue",
            "Breeding",
            "Research",
            "Racing or Competition",
            "Approved Premises or Body",
            "Companion Animal not for Resale or Rehoming",
            "Production",
            "Slaughter",
            "Fattening",
            "Game Restocking",
            "Registered Horses"
          ]
        },
        "exitBIP": {
          "type": "string",
          "minLength": 1,
          "maxLength": 15,
          "description": "Exit Border Inspection Post"
        }
      }
    },

    "DocumentType": {
      "type": "string",
      "description": "Complete superset of all document types across all journeys. Journey-specific schemas restrict to valid subsets at point-of-use.",
      "enum": [
        "airWaybill",
        "billOfLading",
        "cargoManifest",
        "catchCertificate",
        "commercialDocument",
        "commercialInvoice",
        "conformityCertificate",
        "containerManifest",
        "customsDeclaration",
        "docom",
        "healthCertificate",
        "heatTreatmentCertificate",
        "importPermit",
        "inspectionCertificate",
        "itahc",
        "journeyLog",
        "laboratorySamplingResultsForAflatoxin",
        "latestVeterinaryHealthCertificate",
        "letterOfAuthority",
        "licenseOrAuthorisation",
        "listOfIngredients",
        "mycotoxinCertification",
        "originCertificate",
        "other",
        "packingList",
        "phytosanitaryCertificate",
        "processingStatement",
        "proofOfStorage",
        "railwayBill",
        "roadConsignmentNote",
        "seaWaybill",
        "veterinaryHealthCertificate"
      ]
    },

    "AccompanyingDocument": {
      "type": "object",
      "description": "Accompanying document for import notifications. Compatible with ipaffs-imports-notification-schema AccompanyingDocument.",
      "additionalProperties": false,
      "properties": {
        "documentType": {
          "$ref": "#/$defs/DocumentType",
          "description": "Type of accompanying document"
        },
        "documentReference": {
          "type": "string",
          "description": "Additional document reference"
        },
        "documentIssueDate": {
          "type": "string",
          "format": "date",
          "description": "Additional document issue date"
        },
        "attachmentId": {
          "type": "string",
          "description": "The UUID used for the uploaded file in blob storage"
        },
        "attachmentFilename": {
          "type": "string",
          "description": "The original filename of the uploaded file"
        },
        "attachmentContentType": {
          "type": "string",
          "description": "The MIME type of the uploaded file"
        }
      }
    },

    "ApprovedEstablishment": {
      "type": "object",
      "description": "Approved Establishment details. Compatible with ipaffs-imports-notification-schema ApprovedEstablishment.",
      "additionalProperties": false,
      "required": [
        "country",
        "types"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "ID"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255,
          "description": "Name of approved establishment"
        },
        "country": {
          "type": "string",
          "description": "Country of approved establishment"
        },
        "types": {
          "type": "array",
          "description": "Types of approved establishment",
          "items": { "type": "string" }
        },
        "approvalNumber": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "Approval number"
        },
        "section": {
          "type": "string",
          "description": "Section of approved establishment"
        }
      }
    },

    "NominatedContact": {
      "type": "object",
      "description": "Person to be nominated for text and email contact for the consignment. Compatible with ipaffs-imports-notification-schema NominatedContact.",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "maxLength": 32,
          "description": "Name of nominated contact"
        },
        "email": {
          "type": "string",
          "maxLength": 255,
          "description": "Email address of nominated contact"
        },
        "telephone": {
          "type": "string",
          "maxLength": 30,
          "description": "Telephone number of nominated contact"
        }
      }
    },

    "Commodities": {
      "type": "object",
      "description": "Commodities container with complement and parameter arrays. Flattened from partOne.commodities. Journey-specific schemas may extend with additional fields.",
      "properties": {
        "commodityComplement": {
          "type": "array",
          "items": { "$ref": "#/$defs/CommodityComplement" }
        },
        "complementParameterSet": {
          "type": "array",
          "description": "Additional data for commodityComplement containing quantity and identifier data",
          "items": { "$ref": "#/$defs/ComplementParameterSet" }
        },
        "includeNonAblactedAnimals": {
          "type": "boolean",
          "description": "Does consignment contain non-ablacted (unweaned) animals"
        },
        "countryOfOrigin": {
          "$ref": "#/$defs/Country",
          "description": "Consignment's country of origin"
        },
        "regionOfOrigin": {
          "type": "string",
          "minLength": 1,
          "maxLength": 10,
          "description": "Region of country"
        }
      }
    }
  }
}
